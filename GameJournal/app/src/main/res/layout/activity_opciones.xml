<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_blue"
    tools:context=".OpcionesActivity">

    <TextView
        android:id="@+id/textViewOpciones"
        android:layout_width="250dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="OPCIONES"
        android:textSize="25sp"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/edit_text_background_orange"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="30dp"
        android:paddingVertical="8dp">
    </TextView>

    <TextView
        android:id="@+id/textViewCuenta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/textViewOpciones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:text="Tu cuenta"
        android:textAlignment="center"
        android:textSize="25sp"
        android:textColor="@color/white">
    </TextView>

    <TextView
        android:id="@+id/textViewNombreUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="200dp"
        android:text="Nombre de usuario:"
        android:textSize="20sp"
        android:layout_marginStart="50dp"
        android:textColor="@color/white">
    </TextView>

    <TextView
        android:id="@+id/nombreusuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/textViewNombreUsuario"
        android:layout_marginTop="200dp"
        android:layout_marginStart="35dp"
        android:text="test"
        android:textSize="20sp"
        android:textColor="@color/white">
    </TextView>

    <TextView
        android:id="@+id/textViewCorreo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="250dp"
        android:text="Correo electrónico:"
        android:textSize="20sp"
        android:layout_marginStart="50dp"
        android:textColor="@color/white">
    </TextView>

    <TextView
        android:id="@+id/correo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/textViewNombreUsuario"
        android:layout_marginTop="250dp"
        android:layout_marginStart="35dp"
        android:text="test@test.com"
        android:textSize="20sp"
        android:textColor="@color/white">
    </TextView>

    <TextView
        android:id="@+id/textViewContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="300dp"
        android:text="Contrasena:"
        android:textSize="20sp"
        android:layout_marginStart="50dp"
        android:textColor="@color/white">
    </TextView>

    <TextView
        android:id="@+id/contrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/textViewNombreUsuario"
        android:layout_marginTop="300dp"
        android:layout_marginStart="35dp"
        android:text="test"
        android:textSize="20sp"
        android:textColor="@color/white">
    </TextView>

    <Button
        android:id="@+id/botonMostrarContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:text="Mostrar contraseña"
        android:backgroundTint="@color/orange"
        app:layout_constraintTop_toBottomOf="@id/textViewContrasena"
        app:layout_constraintStart_toStartOf="parent"
        android:textColor="@color/white"
        android:layout_marginStart="30dp"
        android:layout_marginTop="30dp">
    </Button>

    <TextView
        android:id="@+id/textViewCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Cerrar sesión"
        android:textAlignment="center"
        android:textSize="20sp"
        android:textColor="@color/orange"
        android:layout_marginBottom="100dp">
    </TextView>

    <TextView
        android:id="@+id/textViewVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Versión de la apliación: 0.0.1"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="40dp">
    </TextView>

</androidx.constraintlayout.widget.ConstraintLayout>
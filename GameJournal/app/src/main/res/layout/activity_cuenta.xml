<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CuentaActivity"
    android:background="@color/dark_blue">

    <TextView
        android:id="@+id/textViewMiCuenta"
        android:layout_width="250dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="MI CUENTA"
        android:textSize="25sp"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/edit_text_background_orange"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="30dp"
        android:paddingVertical="8dp">
    </TextView>

    <TextView
        android:id="@+id/textViewNombreUsuario"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="Nombre de usuario: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewMiCuenta"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="80dp">
    </TextView>

    <TextView
        android:id="@+id/textViewCorreo"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="Correo electrónico: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewNombreUsuario"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp">
    </TextView>

    <TextView
        android:id="@+id/textViewContrasena"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="Contraseña: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewCorreo"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp">
    </TextView>

    <TextView
        android:id="@+id/nombreUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="test"
        app:layout_constraintStart_toEndOf="@id/textViewNombreUsuario"
        app:layout_constraintTop_toBottomOf="@id/textViewMiCuenta"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="80dp">
    </TextView>

    <TextView
        android:id="@+id/correo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="test@test.com"
        app:layout_constraintStart_toEndOf="@id/textViewCorreo"
        app:layout_constraintTop_toBottomOf="@id/nombreUsuario"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp">
    </TextView>

    <TextView
        android:id="@+id/contrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="test"
        app:layout_constraintStart_toEndOf="@id/textViewContrasena"
        app:layout_constraintTop_toBottomOf="@id/correo"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp">
    </TextView>

    <Button
        android:id="@+id/botonMostrarContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:text="Mostrar contraseña"
        android:backgroundTint="@color/orange"
        app:layout_constraintTop_toBottomOf="@id/textViewContrasena"
        app:layout_constraintStart_toStartOf="parent"
        android:textColor="@color/white"
        android:layout_marginStart="30dp"
        android:layout_marginTop="30dp">
    </Button>

</androidx.constraintlayout.widget.ConstraintLayout>